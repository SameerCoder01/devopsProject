<% layout("/layouts/boilerplate.ejs") %>
<%
  const title = typeof pageTitle !== "undefined" ? pageTitle : "Login";
  const subtitle = typeof pageSubtitle !== "undefined" ? pageSubtitle : "Sign in to continue";
  const formAction = typeof actionPath !== "undefined" ? actionPath : "/login";
%>
<div class="row justify-content-center mt-4">
  <div class="col-12 col-md-8 col-lg-6">
    <div class="text-center mb-4">
      <h3><%= title %></h3>
      <p class="text-muted"><%= subtitle %></p>
    </div>
    <form method="POST" action="<%= formAction %>" novalidate class="needs-validation">
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input
          name="username"
          id="username"
          type="text"
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks good!</div>
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input
          name="password"
          id="password"
          type="password"
          class="form-control"
          required
        />
      </div>
      <button class="btn btn-success w-100"><%= title %></button>
    </form>
  </div>
</div>
