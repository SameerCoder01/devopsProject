<% layout("/layouts/boilerplate.ejs") %>
<div class="row justify-content-center py-5">
  <div class="col-12 col-lg-10">
    <div class="text-center mb-4">
      <h1 class="mb-3">Wandrer Portal</h1>
      <p class="lead text-muted">Choose how you want to enter the platform.</p>
    </div>

    <div class="row g-4 justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="card show-card h-100">
          <div class="card-body p-4 text-center">
            <h3 class="mb-3">User Login</h3>
            <p class="text-muted mb-4">See all listings and write reviews.</p>
            <a href="/user/login" class="btn btn-success w-100 mb-3">Continue as User</a>
            <a href="/signup" class="btn btn-outline-dark w-100">Create User Account</a>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-lg-5">
        <div class="card show-card h-100">
          <div class="card-body p-4 text-center">
            <h3 class="mb-3">Admin Login</h3>
            <p class="text-muted mb-4">Manage and add listings from the admin panel.</p>
            <a href="/admin/login" class="btn btn-dark w-100">Continue as Admin</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>